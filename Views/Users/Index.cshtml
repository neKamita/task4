@model UsersPageViewModel
@{
    ViewData["Title"] = "Users";
}

<div class="container-fluid app-container py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-3">
        <div>
            <p class="text-uppercase text-secondary small fw-semibold mb-1">Admin panel</p>
            <h1 class="h3 mb-0">Users</h1>
        </div>
        <div class="table-filter">
            <label for="userFilter" class="visually-hidden">Filter users</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input id="userFilter" class="form-control" type="search" placeholder="Filter" autocomplete="off">
            </div>
        </div>
    </div>

    <form id="bulkUserForm" method="post">
        @Html.AntiForgeryToken()
        <div class="toolbar bg-white border rounded-top px-3 py-2 d-flex flex-wrap align-items-center gap-2" role="toolbar">
            <button type="submit" class="btn btn-primary" asp-action="Block" data-requires-selection data-confirm-title="Block selected users" data-confirm-message="Selected users will be unable to login. If your account is selected, you will be signed out." data-confirm-button="Block">
                <i class="bi bi-lock-fill"></i>
                <span>Block</span>
            </button>
            <button type="submit" class="btn btn-outline-primary btn-icon" asp-action="Unblock" data-bs-toggle="tooltip" data-bs-title="Unblock selected users" data-requires-selection aria-label="Unblock selected users">
                <i class="bi bi-unlock-fill"></i>
            </button>
            <button type="submit" class="btn btn-outline-danger btn-icon" asp-action="Delete" data-bs-toggle="tooltip" data-bs-title="Delete selected users" data-requires-selection data-confirm-title="Delete selected users" data-confirm-message="Selected users will be permanently deleted. If your account is selected, you will be signed out." data-confirm-button="Delete" aria-label="Delete selected users">
                <i class="bi bi-trash-fill"></i>
            </button>
            <button type="submit" class="btn btn-outline-danger btn-icon" asp-action="DeleteUnverified" disabled="@(!Model.HasUnverifiedUsers)" data-bs-toggle="tooltip" data-bs-title="Delete all unverified users" data-confirm-title="Delete unverified users" data-confirm-message="All unverified users will be permanently deleted." data-confirm-button="Delete" aria-label="Delete all unverified users">
                <i class="bi bi-person-x-fill"></i>
            </button>
            <span class="selection-counter ms-sm-2 text-secondary small" aria-live="polite">0 selected</span>
        </div>

        <div class="table-responsive border border-top-0 rounded-bottom bg-white">
            <table class="table align-middle user-table mb-0">
                <thead>
                <tr>
                    <th class="select-col">
                        <input class="form-check-input js-select-all" type="checkbox" aria-label="Select all users">
                    </th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Last login</th>
                    <th>Registered</th>
                </tr>
                </thead>
                <tbody>
                @if (Model.Users.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-5">No users registered.</td>
                    </tr>
                }
                @foreach (var user in Model.Users)
                {
                    var current = user.Id == Model.CurrentUserId;
                    <tr class="@(current ? "table-active" : user.Status == "Blocked" ? "text-secondary" : "")" data-user-search="@($"{user.Name} {user.Email} {user.Status}")">
                        <td class="select-col">
                            <input class="form-check-input js-row-checkbox" type="checkbox" name="selectedIds" value="@user.Id" aria-label="Select @user.Email">
                        </td>
                        <td>
                            <div class="fw-semibold">@user.Name</div>
                            @if (current)
                            {
                                <div class="small text-secondary">Current user</div>
                            }
                        </td>
                        <td class="text-break">@user.Email</td>
                        <td>
                            <span class="badge rounded-pill @StatusClass(user.Status)">@user.Status</span>
                        </td>
                        <td class="text-nowrap font-tabular">@(user.LastLoginAt?.LocalDateTime.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                        <td class="text-nowrap font-tabular">@user.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </form>
</div>

<div class="modal fade" id="confirmBulkModal" tabindex="-1" aria-labelledby="confirmBulkTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="confirmBulkTitle">Confirm action</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="confirmBulkMessage" class="mb-0">This action will update selected users.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmBulkSubmit" class="btn btn-danger">Confirm</button>
            </div>
        </div>
    </div>
</div>

@functions {
    private static string StatusClass(string status)
    {
        return status switch
        {
            "Active" => "text-bg-success",
            "Blocked" => "text-bg-danger",
            _ => "text-bg-warning"
        };
    }
}
