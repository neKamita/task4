<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - Task4</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true">
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    <nav class="navbar navbar-expand bg-white border-bottom">
        <div class="container-fluid app-container">
            <div class="ms-auto d-flex align-items-center gap-3">
                <span class="small text-secondary d-none d-sm-inline">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</span>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button class="btn btn-outline-secondary btn-sm" type="submit">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </div>
        </div>
    </nav>
}

<main>
    @if (TempData["Success"] is string success)
    {
        <div class="container-fluid app-container pt-3">
            <div class="alert alert-success" role="status">@success</div>
        </div>
    }
    @if (TempData["Warning"] is string warning)
    {
        <div class="container-fluid app-container pt-3">
            <div class="alert alert-warning" role="alert">@warning</div>
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="container-fluid app-container pt-3">
            <div class="alert alert-danger" role="alert">@error</div>
        </div>
    }

    @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/app.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
