@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="auth-page">
    <section class="auth-panel">
        <p class="text-uppercase text-secondary small fw-semibold mb-1">User management</p>
        <h1 class="h3 mb-4">Create account</h1>

        <form asp-action="Register" method="post" class="vstack gap-3">
            <div>
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" autocomplete="name" maxlength="120">
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div>
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" autocomplete="email" maxlength="320">
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div>
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" maxlength="128">
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <button class="btn btn-primary btn-lg w-100" type="submit">Register</button>
        </form>

        <p class="auth-switch mb-0">Already registered? <a asp-action="Login">Sign in</a></p>
    </section>
</div>
